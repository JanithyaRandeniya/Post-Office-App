{
  "expo": {
    "name": "ParcelDelivery",
    "slug": "parcel-delivery-app",
    "version": "1.0.0",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "orientation": "portrait",
    
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.parcel.delivery",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app uses your location to show pickup points on the map.",
        "NSCameraUsageDescription": "This app needs access to your camera to take photos of parcels.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photos to upload parcel images.",
        "NSPhotoLibraryAddUsageDescription": "This app needs access to save photos to your library.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.parcel.delivery",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "build": {
        "babel": {
          "include": [
            "expo-image-picker"
          ]
        }
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "This app needs access to your photos to let you upload parcel images.",
          "cameraPermission": "This app needs access to your camera to take photos of parcels."
        }
      ],
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "fe0d68b9-2aab-4d4d-89c5-ffe2479bd1f7"
      }
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "newArchEnabled": true
  }
}
